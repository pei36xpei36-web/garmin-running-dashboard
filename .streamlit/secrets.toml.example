# 這是「範本」。部署到 Streamlit Community Cloud 時，把下面兩個值填好，
# 貼到 Streamlit Cloud 專案的 Settings → Secrets 裡（不要把真值 commit 進 git）。
#
# 本機測試也可以複製這個檔為 .streamlit/secrets.toml 並填入真值（該檔已被 .gitignore 排除）；
# 或者直接寫在專案根目錄的 .env 也可以，兩者擇一即可。

# Supabase Session pooler 連線字串（port 5432、IPv4，適用 Streamlit Cloud）
SUPABASE_DB_URL = "postgresql://postgres.gdiqywcvgxzbyqldbnjw:你的資料庫密碼@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# 儀表板登入密碼（自己設一組）
APP_PASSWORD = "換成你要的密碼"

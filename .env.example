GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# 雲端同步（可留空＝純本機模式）。填了之後 fetch_data.py 會同步寫入 Supabase，
# 本機跑 dashboard 也會改讀 Supabase。用 Supabase「Session pooler」連線字串（port 5432）。
# 範例：postgresql://postgres.xxxx:你的資料庫密碼@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# 儀表板登入密碼（本機測試用；部署時改在 Streamlit Cloud 的 Secrets 設定）。留空＝不需登入。
APP_PASSWORD=

# Obsidian vault 路徑（review.py 週/月復盤寫入位置）。每台電腦路徑可能不同。
# 例：D:\Secondbrain 或 C:\Users\你\Documents\Obsidian Vault
OBSIDIAN_VAULT=
